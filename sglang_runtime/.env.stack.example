# Stack runtime configuration for launches triggered by dashboard backend.
# Copy to .env.stack and adjust values as needed.

# Cluster nodes
MASTER_NODE=spark1
WORKER_NODE=spark2

# Ports
MASTER_PORT=29500
SERVER_PORT=30000

# Model and parallelism
TP_SIZE=2

# Optional overrides
# MODEL_PATH=/home/user/huggingface/Qwen_Qwen3.5-397B-GPTQ-Int4
REMOTE_DIR=/home/user/code/spark-stack
# DIST_ADDR defaults to "${MASTER_NODE}:${MASTER_PORT}" if not set
# DIST_ADDR=spark1:29500

# NCCL / RoCE settings
NCCL_IB_DISABLE=0
NCCL_IB_GID_INDEX=3
NCCL_IB_TIMEOUT=22
NCCL_IB_RETRY_CNT=7
NCCL_IB_SL=3
NCCL_IB_TC=160
NCCL_IB_QPS_PER_CONNECTION=4
NCCL_IB_CUDA_SUPPORT=1
NCCL_NET_GDR_LEVEL=5
NCCL_NET_GDR_READ=1
NCCL_P2P_DISABLE=0
NCCL_IB_HCA=rocep1s0f1

# Network interface binding
CX7_IFACE=enp1s0f1np1
NCCL_SOCKET_IFNAME=enp1s0f1np1
NCCL_IB_IFNAME=enp1s0f1np1

# Runtime behavior
NCCL_DEBUG=WARN
CUDA_GRAPHS=1
SGLANG_DISABLE_TORCHVISION=1
